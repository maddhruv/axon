{
	"name": "axon-ai",
	"version": "0.1.0",
	"description": "Memory engine for AI agents - like a human brain for AIs",
	"type": "module",
	"bin": {
		"axon": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"keywords": [
		"ai",
		"memory",
		"agent",
		"cli"
	],
	"author": "Dhruv Jain",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"glob": "^13.0.6",
		"gray-matter": "^4.0.3",
		"ink": "^6.8.0",
		"nanoid": "^5.1.7",
		"proper-lockfile": "^4.1.2",
		"react": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^25.5.0",
		"@types/proper-lockfile": "^4.1.4",
		"@types/react": "^19.2.14",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"volta": {
		"node": "24.14.0"
	}
}
